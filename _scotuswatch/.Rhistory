majority_coalition <- c(temp_docket$ideology[temp_docket$majority == 2])
if (all(majority_coalition == 'Conservative')){
temp_split <- 1
} else {
temp_split <- 0
}
ideological_split <- bind_rows(ideological_split, data.frame(term = temp_docket$term[1],
docket = temp_docket$docket[1],
split = temp_split))
}
nrow(ideological_split)
ideological_split %>%
group_by(term, split) %>%
summarise(count = n())

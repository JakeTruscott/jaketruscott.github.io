filter(docket_type == 'Petitions') %>%
filter(!lower_court == '') %>%
group_by(lower_court) %>%
summarise(count = n()) %>%
arrange(desc(count)) %>%
mutate(origin_type = ifelse(grepl('United States Court of Appeals for the', lower_court) & grepl('Circuit', lower_court), 'Circuit', 'State/Other')) %>%

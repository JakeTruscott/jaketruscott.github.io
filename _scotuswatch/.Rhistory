scale_x_discrete(breaks = seq(2006, 2022, 2)) +
scale_y_continuous(breaks = seq(50, 300, 50)) +
theme_bw() +
labs(
x = '\nSitting\n',
y = '\nTurnover (Days)\n',
colour = ' ') +
theme(legend.position = 'bottom',
strip.text = element_text(size = 12, colour = 'black', face = 'bold',
margin = margin(b = 10), vjust = -1, hjust = 0.5),

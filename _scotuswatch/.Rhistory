edit_pdf_metadata <- function(input_pdf, output_pdf, metadata) {
# Load the PDF
pdf_object <- qpdf::pdf_object(input_pdf)
# Modify the metadata
modified_pdf <- qpdf::pdf_modify(pdf_object, metadata)
# Write the modified PDF to a new file
qpdf::pdf_write(modified_pdf, output_pdf)
}

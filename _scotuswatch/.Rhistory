scale_y_continuous(breaks = seq(5, 30, 5)) +
labs(x = '',
y = '') +
coord_flip() +
theme_bw() +
scale_fill_identity() +  # Ensure the fill colors are used directly
scale_colour_identity() +  # Ensure the outline colors are used directly

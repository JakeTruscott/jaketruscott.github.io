decisions_ot_23 <- read.csv(file = "ot23_decisions/OT_23_Decisions.csv")
decisions_ot_23 <- decisions_ot_23 %>%
mutate(`Case` = gsub('\\,', '', `Case`),
Decision = gsub('\\,', '', Decision))
decisions_ot_23 %>%
rowwise() %>%
mutate(Coalition = ifelse(any(c_across(ROBERTS:JACKSON) == 1), 1, 0)) %>%
ungroup()
decisions_ot_23 %>%
rowwise() %>%
mutate(Coalition = ifelse(any(c_across(ROBERTS:JACKSON) == 1), 1, 0)) %>%
ungroup() %>%
select(Coalition)
View(decisions_ot_23)
decisions_ot_23 %>%
rowwise() %>%
mutate(Coalition = ifelse(any(c_across(ROBERTS:JACKSON) %in% c(2,4,7)), 1, 0)) %>%
ungroup() %>%
select(Coalition)
decisions_ot_23 %>%
rowwise() %>%
mutate(Coalition = ifelse(any(c_across(ROBERTS:JACKSON) %in% c(2,4,7)), paste0(Coalition, '*'), Coalition)) %>%
ungroup() %>%
select(Coalition)
decisions_ot_23 %>%
rowwise() %>%
mutate(Coalition = ifelse(any(c_across(ROBERTS:JACKSON) %in% c(2,4,7)), paste0(Coalition, '*'), Coalition)) %>%
ungroup() %>%
select(Docket, Date_Argued, Date_Decided, Lower_Court, Decision, Author, Coalition) %>%
rename(docket = Docket) %>%
left_join(shorthand_case_names, by = 'docket') %>%
select(short_hand, docket, Date_Argued, Date_Decided, Lower_Court, Decision, Author, Coalition)
decisions_ot_23 %>%
rowwise() %>%
mutate(Coalition = ifelse(any(c_across(ROBERTS:JACKSON) %in% c(2,4,7)), paste0(Coalition, '*'), Coalition)) %>%
ungroup() %>%
select(Docket, Date_Argued, Date_Decided, Lower_Court, Decision, Author, Coalition) %>%
rename(docket = Docket) %>%
left_join(shorthand_case_names, by = 'docket') %>%
mutate(docket = paste0('(', docket, ')')) %>%
select(short_hand, docket, Date_Argued, Date_Decided, Lower_Court, Decision, Author, Coalition)
decision_descriptions_test <- decisions_ot_23 %>%
rowwise() %>%
mutate(Coalition = ifelse(any(c_across(ROBERTS:JACKSON) %in% c(2,4,7)), paste0(Coalition, '*'), Coalition)) %>%
ungroup() %>%
select(Docket, Date_Argued, Date_Decided, Lower_Court, Decision, Author, Coalition) %>%
rename(docket = Docket) %>%
left_join(shorthand_case_names, by = 'docket') %>%
mutate(docket = paste0('(', docket, ')')) %>%
mutate(description = 'This is a test. (Name of Host Station) is conducting a test of the Emergency Broadcast System. This is only a test.') %>%
select(short_hand, description, docket, Date_Argued, Date_Decided, Lower_Court, Decision, Author, Coalition)
write.table(decisions_descriptions_test, file = 'state_pack_OT23/Tables/decision_tables/decision_description_1.csv')
write.table(decision_descriptions_test, file = 'state_pack_OT23/Tables/decision_tables/decision_description_1.csv', sep = ',', quote = FALSE, row.names = F)
write.table(decision_descriptions_test, file = 'stat_pack_OT23/Tables/decision_tables/decision_description_1.csv', sep = ',', quote = FALSE, row.names = F)

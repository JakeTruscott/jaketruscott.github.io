mutate(across(ROBERTS:JACKSON, ~ case_when(
. == 100 ~ 'Majority',
. %in% c(2, 4, 5, 7) ~ 'Concurrence',
. %in% c(-1, -3) ~ 'Dissent',
.default = NA
))) %>%
pivot_longer(cols = ROBERTS:JACKSON, names_to = "opinion_writer", values_to = "opinion_type") %>%
filter(!is.na(opinion_writer)) %>%

group_by(term, coalition) %>%
summarise(count = n()) %>%
group_by(term) %>%
reframe(total_cases = sum(count),
count = count,
coalition = coalition) %>%
mutate(percent = round((count/total_cases)*100, 2),
term = paste0(term, ' Term (', total_cases, ')')) %>%
ggplot(aes(x = "", y = percent, fill = coalition)) +

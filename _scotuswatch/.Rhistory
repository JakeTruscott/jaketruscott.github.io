edit_pdf_metadata <- function(input_pdf, output_pdf, metadata) {
# Use qpdf to copy the original PDF and apply new metadata
qpdf::pdf_copy(input_pdf, output_pdf, metadata = metadata)
}
edit_pdf_metadata(input_pdf, output_pdf, metadata)
create_exiftool_args <- function(metadata) {
args <- unlist(lapply(names(metadata), function(key) {
c(paste0("-", key, "="), metadata[[key]])
}))
return(args)
}
# Edit the metadata of an existing PDF using exiftool
edit_pdf_metadata <- function(input_pdf, output_pdf, metadata) {
# Copy the original PDF to a new file
file.copy(input_pdf, output_pdf, overwrite = TRUE)
# Create exiftool arguments
exiftool_args <- create_exiftool_args(metadata)
# Run exiftool to modify the metadata
system2("exiftool", c(exiftool_args, output_pdf))
# Remove the original file created by exiftool (it creates a backup with _original suffix)
file.remove(paste0(output_pdf, "_original"))
}
edit_pdf_metadata(input_pdf, output_pdf, metadata)
edit_pdf_metadata(input_pdf, output_pdf, metadata)

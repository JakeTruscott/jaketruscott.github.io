coord_polar(theta = "y", start = 0) +
facet_wrap(~term) +
theme_void() +
labs(
x = ' ',
y = ' ',
fill = ' ') +
scale_fill_manual(values = c('deepskyblue3', 'coral')) +
geom_label(aes(label = paste0(percent, ' %')), position = position_stack(vjust = 0.5), color = "gray5", size=5, show.legend = F) +

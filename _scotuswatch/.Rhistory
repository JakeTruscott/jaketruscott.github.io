sitting == 'December' ~ 'Dec',
sitting == 'January' ~ 'Jan',
sitting == 'February' ~ 'Feb',
sitting == 'March' ~ 'Mar',
sitting == 'April' ~ 'Apr')) %>%
mutate(sitting = factor(sitting, levels = c('Oct', 'Nov', 'Dec', 'Jan', "Feb", 'Mar', 'Apr'))) %>%
ggplot(aes(x = factor(sitting), y = average_turnover)) +
geom_bar(stat = 'identity', colour = 'gray5', fill = 'gray50') +

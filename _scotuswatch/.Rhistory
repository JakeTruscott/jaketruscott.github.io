pivot_wider(names_from = speaker, values_from = total_word_count, names_prefix = "word_count_")
names(oa) <- gsub('(CHIEF JUSTICE |JUSTICE )', '', names(oa))
names(oa) <- gsub('word_count_', '', names(oa))
totals <- oa %>%
select(-case_name) %>%
summarise_all(.funs = sum, na.rm = T)

petitioner_counsel <- data.frame()
for (i in 1:nrow(combined_dockets)){
temp_row <- combined_dockets[i,]
temp_petitioner_counsel <- data.frame(temp_row[['counsel']][[1]][['Petitioner']])
temp_petitioner_counsel <- temp_petitioner_counsel[names(temp_petitioner_counsel) %in% c('name', 'location', 'contact')]
if (nrow(temp_petitioner_counsel) == 0){
next
}
names(temp_petitioner_counsel) <- c('petitioner_counsel_name', 'petitioner_counsel_location', 'petitioner_counsel_contact')
temp_complete_row <- data.frame(
docket = temp_row$docket_number,
filing_year = temp_row$filing_year,
case_title = temp_row$case_title,
lower_court = temp_row$lower_court,
petitioner = gsub(' v\\. .*', '', temp_row$case_title)) %>%
bind_cols(data.frame(temp_petitioner_counsel))
petitioner_counsel <- bind_rows(petitioner_counsel, temp_complete_row)
if (i %% 1000 == 0){
message('Completed ', i, ' of ', nrow(combined_dockets))
}
}
writexl::write_xlsx(petitioner_counsel, path = 'C:/Users/Jake Truscott/Desktop/petitioner_counsel.xlsx')
